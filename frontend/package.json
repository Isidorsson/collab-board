{
  "name": "collab-board-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build && node -e \"require('fs').writeFileSync('../cmd/server/web/dist/.gitkeep', '')\"",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json --threshold error",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
